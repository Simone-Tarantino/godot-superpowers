{
  "permissions": {
    "allow": [
      "Bash(godot *)",
      "Bash(gdformat *)",
      "Bash(gdlint *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(pipx install gdtoolkit*)",
      "Bash(pip install gdtoolkit*)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(chmod +x *)",
      "Bash(chmod 755 *)",
      "Bash(chmod 644 *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(tar *)",
      "Bash(zipalign *)",
      "Bash(apksigner *)",
      "Bash(signtool *)",
      "Bash(codesign *)",
      "Bash(productbuild *)",
      "Bash(productsign *)",
      "Bash(xcrun *)",
      "Bash(notarytool *)",
      "Bash(hdiutil *)",
      "Bash(magick *)",
      "Bash(convert *)",
      "Bash(iconutil *)",
      "Bash(sips *)",
      "Bash(keytool *)",
      "Bash(xattr *)",
      "Bash(rm -rf addons/*/.git)",
      "Bash(rm -rf addons/*/.git/)",
      "Read(**/*.gd)",
      "Read(**/*.gdshader)",
      "Read(**/*.tscn)",
      "Read(**/*.tres)",
      "Read(**/*.gdextension)",
      "Read(**/*.md)",
      "Read(**/*.json)",
      "Read(**/*.cfg)",
      "Read(**/*.gutconfig.json)",
      "Read(**/*.toml)",
      "Read(**/*.yml)",
      "Read(**/*.yaml)",
      "Read(**/.gitignore)",
      "Read(**/.gdignore)",
      "Read(project.godot)",
      "Read(default_bus_layout.tres)",
      "Read(export_presets.cfg)"
    ],
    "deny": [
      "Read(.godot/)",
      "Read(.godot/**)",
      "Write(.godot/)",
      "Write(.godot/**)",
      "Read(.import/)",
      "Read(.import/**)",
      "Read(builds/)",
      "Read(builds/**)",
      "Read(exports/)",
      "Read(exports/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(android/)",
      "Read(android/**)",
      "Read(*.keystore)",
      "Read(*.cer)",
      "Read(*.p12)",
      "Read(*.mobileprovision)",
      "Read(*.remap)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$CLAUDE_PROJECT_DIR/.claude}/scripts/hooks/gdformat-gd.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$CLAUDE_PROJECT_DIR/.claude}/scripts/hooks/check-tscn.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$CLAUDE_PROJECT_DIR/.claude}/scripts/hooks/dep-integrity.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$CLAUDE_PROJECT_DIR/.claude}/scripts/hooks/verifier-reminder.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$CLAUDE_PROJECT_DIR/.claude}/scripts/hooks/stop-gdlint.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$CLAUDE_PROJECT_DIR/.claude}/scripts/hooks/pre-bash-guard.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-$CLAUDE_PROJECT_DIR/.claude}/scripts/hooks/session-start.sh\""
          }
        ]
      }
    ]
  }
}
